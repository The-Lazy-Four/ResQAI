# Google Gemini API Key - Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# OpenRouter Keys - Get from https://openrouter.ai/keys
OPENROUTER_PRIMARY_API_KEY=your-openrouter-primary-key
OPENROUTER_SECONDARY_API_KEY=your-openrouter-secondary-key

# Groq API Key - Get from https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# AI provider fallback order
AI_PROVIDER_PRIORITY=["gemini","openrouter_primary","openrouter_secondary","grok","fallback"]

# Model configuration
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct
GROQ_MODEL=llama-3.1-70b-versatile

# Timeout in milliseconds
AI_TIMEOUT=30000

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./emergencies.db

# Roboflow API Key
ROBOFLOW_API_KEY=your-roboflow-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-auth/callback
